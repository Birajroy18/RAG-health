# Copy this file to secrets.toml and fill in your values.
#   copy secrets.toml.example secrets.toml
#
# secrets.toml is gitignored — do not commit real keys.
# For Streamlit Cloud: paste the same keys in the app Secrets manager.

OPENROUTER_API_KEY = "sk-or-your-openrouter-key"

# Optional — reliable free instruct model (avoid openrouter/free reasoning routers)
OPENROUTER_MODEL = "meta-llama/llama-3.2-3b-instruct:free"
OPENROUTER_FALLBACK_MODELS = "meta-llama/llama-3.3-70b-instruct:free,openrouter/free"

# Optional - preferred model path when available.
GEMINI_API_KEY = "your-gemini-api-key"
GEMINI_MODEL = "gemini-2.5-flash"

# Optional — free from https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY = ""
NCBI_EMAIL = "you@example.com"
NCBI_TOOL = "medical-rag-assistant"
